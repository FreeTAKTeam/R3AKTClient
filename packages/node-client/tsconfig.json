{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "ESNext",
                            "moduleResolution":  "Bundler",
                            "strict":  true,
                            "declaration":  true,
                            "outDir":  "dist",
                            "lib":  [
                                        "ES2022",
                                        "DOM"
                                    ],
                            "skipLibCheck":  true
                        },
    "include":  [
                    "src/index.ts",
                    "src/generated/**/*.ts"
                ],
    "exclude":  [
                    "src/**/*.spec.ts"
                ]
}
